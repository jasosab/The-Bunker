# ========================================
# CONFIGURACION - TheBunker Backend
# ========================================

# Puerto del servidor (Vercel asigna automáticamente en producción)
PORT=5000

# Entorno de ejecución (development | production)
NODE_ENV=production

# ========================================
# BASE DE DATOS - MongoDB Atlas
# ========================================

# MongoDB Atlas (requerido para producción)
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ========================================
# SEGURIDAD - JWT (JSON Web Tokens)
# ========================================

# Clave secreta para firmar tokens (CAMBIAR EN PRODUCCION)
JWT_SECRET=tu_clave_secreta_segura_aqui

# Tiempo de expiración del token (7d = 7 días)
JWT_EXPIRE=7d

# ========================================
# CORS - Origen permitido para peticiones
# ========================================

# URL del frontend desplegado en Vercel
CORS_ORIGIN=https://tu-frontend.vercel.app
