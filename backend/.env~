# ========================================
# CONFIGURACION - TheBunker Backend
# ========================================

# Puerto del servidor (por defecto: 5000)
PORT=5000

# Entorno de ejecución (development | production)
NODE_ENV=development

# ========================================
# BASE DE DATOS - MongoDB
# ========================================

# MongoDB Local (instala MongoDB en tu PC)
MONGODB_URI=mongodb://localhost:27017/TheBunker

# MongoDB Atlas (recomendado - gratis en la nube)
# Descomenta y usa esta línea si usas MongoDB Atlas:
# MONGODB_URI=mongodb+srv://tu-usuario:tu-password@cluster0.xxxxx.mongodb.net/TheBunker?retryWrites=true&w=majority

# ========================================
# SEGURIDAD - JWT (JSON Web Tokens)
# ========================================

# Clave secreta para firmar tokens (¡CAMBIAR EN PRODUCCION!)
# Genera una segura en: https://randomkeygen.com/
JWT_SECRET=mi_super_clave_secreta_cambiar_en_produccion_123456

# Tiempo de expiración del token (7d = 7 días)
JWT_EXPIRE=7d

# ========================================
# CORS - Origen permitido para peticiones
# ========================================

# URL del frontend (Vue.js)
CORS_ORIGIN=http://localhost:3000
